{
  "expo": {
    "name": "mobile-app",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show it on the map.",
        "NSPhotoLibraryUsageDescription": "Aplicația are nevoie de acces la galeria foto pentru a adăuga imagini la evenimente."
      }
    },
    "android": {
      "package": "com.anamaria.undemergem",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_MEDIA_IMAGES"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBhaJLtClFHxyk708C256eotGa2q5cFwjc"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "29a7a544-1bf7-49af-904d-492bf9acecf6"
      }
    },
    "owner": "anabm16",
    "plugins": [
      "expo-web-browser",
      "expo-font"
    ]
  }
}
